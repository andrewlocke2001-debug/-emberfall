// Emberfall persistence schema.
//
// Postgres everywhere (Neon) — local dev and production share the engine so
// one set of migrations is the truth. A Prisma driver adapter must match the
// schema provider, which rules out SQLite-locally/PG-in-prod with one schema
// (deviation from the kit runbook, logged in design/PROGRESS.md).
// One table so far; keep this file boring.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// A login account. Guests get an auto-generated username + a random password
// hash (they authenticate via the token kept in localStorage, never a typed
// password). Registered accounts set their own password.
model Account {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  isGuest      Boolean  @default(false)
  // Ironman mode (P10): self-sufficient — no trading or Exchange; marked on
  // hiscores. Chosen at registration, permanent.
  ironman      Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// A persisted character. `id` is the owning Account's id (one character per
// account for now — a 1:1 by shared id, kept additive so no destructive
// migration was needed). Pre-auth rows (id = old client playerId) are simply
// orphaned and never loaded.
model Player {
  id         String   @id
  name       String
  zone       String   @default("meadowbrook")
  x          Float
  y          Float
  hp         Int
  maxHp      Int
  level      Int      @default(1)
  meleeXp    Int      @default(0)
  vitalityXp Int      @default(0)
  miningXp   Int      @default(0)
  fishingXp  Int      @default(0)
  smithingXp Int      @default(0)
  cookingXp  Int      @default(0)
  restedXp   Int      @default(0)
  // Inventory as JSON: an array of { itemId, qty } stacks (see @mmo/shared
  // systems/inventory). The server is the sole writer; shape is validated there.
  inventory  Json     @default("[]")
  // Equipment as JSON: a { slot: itemId } map (see @mmo/shared systems/equipment).
  equipment  Json     @default("{}")
  // Bank as JSON: an array of { itemId, qty } stacks (town storage).
  bank       Json     @default("[]")
  // Quest log as JSON: array of { questId, status, progress[] }.
  quests     Json     @default("[]")
  // Friends as JSON: array of friend display names.
  friends    Json     @default("[]")
  // Gear durability as JSON: { itemId: remaining } (P8; missing = undamaged).
  durability Json     @default("{}")
  // Active hunt task as JSON: { mob, remaining, points } or null (P10).
  hunt       Json?
  // Hunt point balance (P10 point shop).
  huntPoints Int      @default(0)
  // Chosen achievement title (P10), shown to others.
  title      String?
  // Owns a mount (P11): a one-time purchase, then rideable for good.
  hasMount   Boolean  @default(false)
  // Guild membership (loose reference, consistent with the id conventions).
  guildId    String?
  guildRank  String?
  createdAt  DateTime @default(now())
  lastSeen   DateTime @updatedAt

  @@index([guildId])
}

// A guild: the durable social unit (name + [TAG] + a leader account id).
// Membership lives on Player.guildId/guildRank.
model Guild {
  id        String   @id @default(cuid())
  name      String   @unique
  tag       String   @unique
  leaderId  String
  createdAt DateTime @default(now())
}

// An open order on the Exchange (async order-book market, P8.3). Items/coins are
// escrowed off the player's bag when posted; fills accrue proceeds/bought items
// as `*ToCollect` (the owner may be offline), claimed later into their bag.
model ExchangeOrder {
  id             String   @id @default(cuid())
  accountId      String
  side           String // "buy" | "sell"
  itemId         String
  qty            Int // original quantity
  remaining      Int // unfilled quantity
  price          Int // per-unit limit price (coins)
  coinsToCollect Int      @default(0) // sale proceeds + buy refunds awaiting collection
  itemsToCollect Int      @default(0) // bought items awaiting collection
  createdAt      DateTime @default(now())

  @@index([itemId, side])
  @@index([accountId])
}

// A completed Exchange trade — the price history feed.
model ExchangeTrade {
  id     String   @id @default(cuid())
  itemId String
  price  Int
  qty    Int
  at     DateTime @default(now())

  @@index([itemId, at])
}

// Economy audit ledger (kit rule #6): EVERY item creation (+delta) and
// destruction (-delta) appends a row here, so total items in the world always
// reconciles to created − destroyed. Append-only; never updated or deleted.
model LedgerEntry {
  id      String   @id @default(cuid())
  at      DateTime @default(now())
  // Owning account id, or a sentinel like "world" for non-player sources.
  account String
  itemId  String
  delta   Int
  // Why it happened: "gm_give", "loot", "bank_deposit", "consume", …
  reason  String

  @@index([account])
  @@index([itemId])
}
