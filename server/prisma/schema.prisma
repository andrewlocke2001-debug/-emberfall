// Emberfall persistence schema.
//
// Postgres everywhere (Neon) — local dev and production share the engine so
// one set of migrations is the truth. A Prisma driver adapter must match the
// schema provider, which rules out SQLite-locally/PG-in-prod with one schema
// (deviation from the kit runbook, logged in design/PROGRESS.md).
// One table so far; keep this file boring.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// A persisted character. `id` is the stable playerId the client generates and
// stores locally (real auth replaces this in P1 — same row, new lookup key).
model Player {
  id        String   @id
  name      String
  zone      String   @default("verdant-vale")
  x         Float
  y         Float
  hp        Int
  maxHp     Int
  level     Int      @default(1)
  createdAt DateTime @default(now())
  lastSeen  DateTime @updatedAt
}
